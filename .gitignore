# ---------------------------------------------------------------------------
# Unity generated
# ---------------------------------------------------------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Never ignore Asset meta data — Unity's entire reference system depends on it.
!/[Aa]ssets/**/*.meta

# ---------------------------------------------------------------------------
# Asset store / packages
# ---------------------------------------------------------------------------
/[Aa]ssets/[Aa]sset[Ss]tore[Tt]ools*
/[Aa]ssets/[Pp]lugins/[Ee]ditor/JetBrains*

# ---------------------------------------------------------------------------
# Addressables build artifacts (regenerated; do NOT commit)
# ---------------------------------------------------------------------------
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Ss]erver[Dd]ata/
/[Aa]ddressable[Aa]ssets[Dd]ata/link.xml

# ---------------------------------------------------------------------------
# IDE
# ---------------------------------------------------------------------------
.vs/
.idea/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Build outputs
# ---------------------------------------------------------------------------
*.apk
*.aab
*.unitypackage
*.app
*.ipa
crashlytics-build.properties

# ---------------------------------------------------------------------------
# SECRETS — never commit these.
# Firebase/AdMob config files carry project-identifying keys and are environment
# specific. They are injected by CI from encrypted secrets. See docs/SECRETS.md.
# ---------------------------------------------------------------------------
google-services.json
GoogleService-Info.plist
/[Aa]ssets/[Ss]treaming[Aa]ssets/google-services*
/[Aa]ssets/[Ss]treaming[Aa]ssets/GoogleService*
*.keystore
*.jks
keystore.properties
secrets.env
.env
.env.*
!.env.example
/[Aa]ssets/[Rr]esources/LocalSecrets.asset

graphify-out
